{
  "expo": {
    "name": "Posta Kiosk",
    "slug": "kiosk",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "postakiosk",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A3B26"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "buildNumber": "9",
      "bundleIdentifier": "com.posta.kiosk",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access needed to capture photos for postcards.",
        "NSPhotoLibraryUsageDescription": "Photo library access needed to upload photos for postcards.",
        "NSLocationWhenInUseUsageDescription": "Location is used to display your kiosk's city on the postcard.",
        "UIRequiresFullScreen": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2A3B26"
      },
      "package": "com.posta.kiosk",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Posta to access your photos.",
          "cameraPermission": "Allow Posta to use your camera."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Posta to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97439390-1dec-4b6c-91cb-35a6abafa752"
      }
    },
    "owner": "umardaxs-organization"
  }
}
