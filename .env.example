# Copy this file to .env and fill in your values
# Expo uses EXPO_PUBLIC_ prefix for client-side env vars

# Backend API base URL (HTTP)
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# WebSocket base URL (optional — defaults to API_BASE_URL with ws:// scheme)
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:5000

# Location name printed on the postcard bottom border (uppercase recommended)
# e.g. SEDONA, ARIZONA  |  HORSESHOE BEND, ARIZONA  |  ANTELOPE CANYON, ARIZONA
EXPO_PUBLIC_LOCATION_NAME=SEDONA, ARIZONA
